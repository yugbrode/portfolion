/* ====================================================
   THEME SYSTEM
   ==================================================== */
function setTheme(name){
  document.body.className = name ? 'theme-'+name : '';
  document.querySelectorAll('.theme-dot').forEach(d=>{
    d.classList.toggle('active', d.title.toLowerCase()===(name||'void'));
  });
  updateAccentColor();
}

function getAccentColor(){
  const map = {'':232,'aurora':0,'nova':167,'ember':255,'frost':125};
  const r = {'':232,'aurora':0,'nova':167,'ember':255,'frost':125};
  const g = {'':255,'aurora':245,'nova':139,'ember':107,'frost':211};
  const b = {'':71,'aurora':212,'nova':250,'ember':53,'frost':252};
  const t = document.body.className.replace('theme-','');
  return {r:r[t]||232,g:g[t]||255,b:b[t]||71};
}

function updateAccentColor(){
  const c = getAccentColor();
  accentRGB = c;
}

let accentRGB = {r:232,g:255,b:71};

/* ====================================================
   NAVIGATION
   ==================================================== */
function navigate(page){
  document.querySelectorAll('.page').forEach(p=>{
    p.classList.remove('active');
  });
  setTimeout(()=>{
    const el = document.getElementById('page-'+page);
    if(el){ el.classList.add('active'); }
    document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
    const nav = document.getElementById('nav-'+page);
    if(nav) nav.classList.add('active');
    window.scrollTo({top:0,behavior:'smooth'});
    if(page==='projects') renderAllProjects('all');
    if(page==='about') renderSkills(['about-skills1','about-skills2']);
    setTimeout(()=>initReveal(),100);
  },50);
  spawnPageSparks();
}

/* ====================================================
   SPARKS / PARTICLE BURST ON CURSOR & CLICK
   ==================================================== */
const sparksCanvas = document.getElementById('sparks-canvas');
const sCtx = sparksCanvas.getContext('2d');
sparksCanvas.width = window.innerWidth;
sparksCanvas.height = window.innerHeight;
window.addEventListener('resize',()=>{sparksCanvas.width=window.innerWidth;sparksCanvas.height=window.innerHeight});

let sparks = [];
let mouseX = 0, mouseY = 0;
let lastSparkX = 0, lastSparkY = 0;

class Spark {
  constructor(x,y,burst=false){
    this.x=x; this.y=y;
    const angle = burst ? Math.random()*Math.PI*2 : (Math.random()-0.5)*1.2;
    const speed = burst ? Math.random()*5+2 : Math.random()*2+0.5;
    this.vx=Math.cos(angle)*speed;
    this.vy=Math.sin(angle)*speed - (burst?0:1);
    this.life=1; this.decay=burst?0.025+Math.random()*0.02:0.04+Math.random()*0.04;
    this.size=burst?Math.random()*3+1:Math.random()*2+0.5;
    this.color=burst?`rgba(${accentRGB.r},${accentRGB.g},${accentRGB.b}`:`rgba(${accentRGB.r},${accentRGB.g},${accentRGB.b}`;
  }
  update(){
    this.x+=this.vx; this.y+=this.vy;
    this.vy+=0.06; this.life-=this.decay; this.vx*=0.98;
  }
  draw(){
    sCtx.save();
    sCtx.globalAlpha=Math.max(0,this.life);
    sCtx.fillStyle=this.color+`,${Math.max(0,this.life)})`;
    sCtx.shadowBlur=8; sCtx.shadowColor=this.color+',0.8)';
    sCtx.beginPath();
    sCtx.arc(this.x,this.y,this.size,0,Math.PI*2);
    sCtx.fill();
    sCtx.restore();
  }
}

document.addEventListener('mousemove',e=>{
  mouseX=e.clientX; mouseY=e.clientY;
  if(Math.hypot(mouseX-lastSparkX,mouseY-lastSparkY)>18){
    for(let i=0;i<2;i++) sparks.push(new Spark(mouseX,mouseY,false));
    lastSparkX=mouseX; lastSparkY=mouseY;
  }
  moveCursor(mouseX,mouseY);
});

document.addEventListener('click',e=>{
  for(let i=0;i<28;i++) sparks.push(new Spark(e.clientX,e.clientY,true));
});

function spawnPageSparks(){
  const cx=window.innerWidth/2, cy=window.innerHeight/2;
  for(let i=0;i<50;i++) sparks.push(new Spark(cx,cy,true));
}

function animateSparks(){
  sCtx.clearRect(0,0,sparksCanvas.width,sparksCanvas.height);
  sparks = sparks.filter(s=>s.life>0);
  sparks.forEach(s=>{s.update();s.draw()});
  requestAnimationFrame(animateSparks);
}
animateSparks();

/* ====================================================
   CUSTOM CURSOR
   ==================================================== */
const cursor = document.getElementById('cursor');
const cursorTrail = document.getElementById('cursor-trail');
let trailX=0,trailY=0,cursorX=0,cursorY=0;

function moveCursor(x,y){cursorX=x;cursorY=y;cursor.style.left=x+'px';cursor.style.top=y+'px';}

function animateCursorTrail(){
  trailX+=(cursorX-trailX)*0.1;
  trailY+=(cursorY-trailY)*0.1;
  cursorTrail.style.left=trailX+'px';
  cursorTrail.style.top=trailY+'px';
  requestAnimationFrame(animateCursorTrail);
}
animateCursorTrail();

document.querySelectorAll('a,button,.project-card,.tab-btn,.filter-btn,.theme-dot').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cursor.style.width='24px';cursor.style.height='24px';cursorTrail.style.width='60px';cursorTrail.style.height='60px'});
  el.addEventListener('mouseleave',()=>{cursor.style.width='12px';cursor.style.height='12px';cursorTrail.style.width='36px';cursorTrail.style.height='36px'});
});

/* ====================================================
   MUSIC SYSTEM — PROCEDURAL AMBIENT SYNTH (WEB AUDIO)
   ==================================================== */
let audioCtx = null, musicPlaying = false;
let oscillators = [], gainNodes = [], masterGain = null;

const NOTES = [261.63,293.66,329.63,349.23,392.00,440.00,493.88,523.25];
const CHORD_PROGRESSIONS = [
  [0,2,4],[0,2,5],[1,3,5],[0,3,4]
];
let chordTimer = null, noteTimer = null;

function createAudioContext(){
  if(audioCtx) return;
  audioCtx = new (window.AudioContext||window.webkitAudioContext)();
  masterGain = audioCtx.createGain();
  masterGain.gain.value = 0.22;
  const comp = audioCtx.createDynamicsCompressor();
  masterGain.connect(comp);
  comp.connect(audioCtx.destination);
}

function playAmbientNote(freq,type='sine',dur=2.4,vol=0.08){
  if(!audioCtx) return;
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  const filter = audioCtx.createBiquadFilter();
  filter.type='lowpass'; filter.frequency.value=900;
  osc.type=type; osc.frequency.value=freq;
  osc.connect(filter); filter.connect(gain); gain.connect(masterGain);
  gain.gain.setValueAtTime(0,audioCtx.currentTime);
  gain.gain.linearRampToValueAtTime(vol,audioCtx.currentTime+0.4);
  gain.gain.linearRampToValueAtTime(0,audioCtx.currentTime+dur);
  osc.start(audioCtx.currentTime);
  osc.stop(audioCtx.currentTime+dur+0.1);
}

function playChord(){
  if(!musicPlaying) return;
  const prog = CHORD_PROGRESSIONS[Math.floor(Math.random()*CHORD_PROGRESSIONS.length)];
  prog.forEach((ni,i)=>{
    setTimeout(()=>{
      playAmbientNote(NOTES[ni]*0.5,'sine',3.5,0.06);
      playAmbientNote(NOTES[ni],'triangle',3.5,0.04);
    },i*180);
  });
  // melody note
  setTimeout(()=>{
    const mn = NOTES[Math.floor(Math.random()*NOTES.length)];
    playAmbientNote(mn,'sine',1.8,0.05);
  },600);
  chordTimer = setTimeout(playChord,4200);
}

function toggleMusic(){
  if(!musicPlaying){
    createAudioContext();
    musicPlaying=true;
    document.getElementById('music-btn').classList.add('playing');
    document.getElementById('music-label').textContent='Playing';
    playChord();
  } else {
    musicPlaying=false;
    document.getElementById('music-btn').classList.remove('playing');
    document.getElementById('music-label').textContent='Music';
    clearTimeout(chordTimer);
  }
}

/* ====================================================
   THREE.JS — HERO 3D SCENE WITH BIRDS + PARTICLES
   ==================================================== */
(function initThreeScene(){
  const canvas = document.getElementById('hero-canvas');
  const renderer = new THREE.WebGLRenderer({canvas,antialias:true,alpha:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setSize(canvas.parentElement.clientWidth,canvas.parentElement.clientHeight);
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.1;
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60,canvas.clientWidth/canvas.clientHeight,0.1,1000);
  camera.position.set(0,0,18);

  // Fog
  scene.fog = new THREE.FogExp2(0x060608, 0.018);

  // Ambient
  scene.add(new THREE.AmbientLight(0x1a1a2e,2));

  // Key light
  const keyLight = new THREE.DirectionalLight(0xffffff,1.8);
  keyLight.position.set(10,20,10);
  keyLight.castShadow=true;
  scene.add(keyLight);

  // Accent light (accent colour)
  const accentLight = new THREE.PointLight(0xe8ff47,3,60);
  accentLight.position.set(-8,5,5);
  scene.add(accentLight);

  const fillLight = new THREE.PointLight(0x4444ff,1.5,40);
  fillLight.position.set(10,-5,-10);
  scene.add(fillLight);

  /* --- STAR FIELD --- */
  const starCount = 3000;
  const starGeo = new THREE.BufferGeometry();
  const starPos = new Float32Array(starCount*3);
  for(let i=0;i<starCount*3;i++) starPos[i]=(Math.random()-0.5)*400;
  starGeo.setAttribute('position',new THREE.BufferAttribute(starPos,3));
  const starMat = new THREE.PointsMaterial({color:0xffffff,size:0.22,sizeAttenuation:true,transparent:true,opacity:0.7});
  scene.add(new THREE.Points(starGeo,starMat));

  /* --- FLOATING GLOWING ORB (Planet) --- */
  const orbGeo = new THREE.SphereGeometry(3.5,64,64);
  const orbMat = new THREE.MeshStandardMaterial({
    color:0x0d1f3c,metalness:0.6,roughness:0.3,
    emissive:new THREE.Color(0.04,0.08,0.22),emissiveIntensity:1
  });
  const orb = new THREE.Mesh(orbGeo,orbMat);
  orb.position.set(5,0,-4);
  orb.castShadow=true;
  scene.add(orb);

  // Orb atmosphere ring
  const ringGeo = new THREE.TorusGeometry(4.6,0.25,32,120);
  const ringMat = new THREE.MeshStandardMaterial({color:0xe8ff47,metalness:0.9,roughness:0.1,transparent:true,opacity:0.35,emissive:new THREE.Color(0.6,1,0.1),emissiveIntensity:0.8});
  const ring = new THREE.Mesh(ringGeo,ringMat);
  ring.position.copy(orb.position);
  ring.rotation.x = Math.PI/2.4;
  scene.add(ring);

  // Orb glow (additive sphere)
  const glowGeo = new THREE.SphereGeometry(4.8,32,32);
  const glowMat = new THREE.MeshBasicMaterial({color:0x2244aa,transparent:true,opacity:0.07,side:THREE.BackSide});
  const glow = new THREE.Mesh(glowGeo,glowMat);
  glow.position.copy(orb.position);
  scene.add(glow);

  /* --- PROCEDURAL BIRDS --- */
  function makeBird(color){
    const group = new THREE.Group();
    // body
    const bodyGeo = new THREE.ConeGeometry(0.08,0.4,4);
    const mat = new THREE.MeshStandardMaterial({color,metalness:0.3,roughness:0.6});
    const body = new THREE.Mesh(bodyGeo,mat);
    body.rotation.z = Math.PI/2;
    group.add(body);
    // wings
    const wingGeo = new THREE.PlaneGeometry(0.7,0.18);
    const wingMat = new THREE.MeshStandardMaterial({color,side:THREE.DoubleSide,transparent:true,opacity:0.9});
    const wingL = new THREE.Mesh(wingGeo,wingMat);
    wingL.position.set(0,0.04,0.2);
    const wingR = new THREE.Mesh(wingGeo,wingMat);
    wingR.position.set(0,0.04,-0.2);
    group.add(wingL,wingR);
    group.userData.wingL=wingL;
    group.userData.wingR=wingR;
    return group;
  }

  const birds = [];
  const birdColors = [0xffd080,0xff8844,0x88ddff,0xffffff,0xffaacc,0xaaffcc];
  for(let i=0;i<18;i++){
    const bird = makeBird(birdColors[i%birdColors.length]);
    const r = 7+Math.random()*8;
    const theta = Math.random()*Math.PI*2;
    const phi = (Math.random()-0.5)*0.8;
    bird.position.set(r*Math.cos(theta),r*Math.sin(phi)*2+1,r*Math.sin(theta)-6);
    bird.userData.radius=r;
    bird.userData.theta=theta;
    bird.userData.phi=phi;
    bird.userData.speed=0.004+Math.random()*0.006;
    bird.userData.wingPhase=Math.random()*Math.PI*2;
    bird.userData.wobble=Math.random()*0.5;
    scene.add(bird);
    birds.push(bird);
  }

  /* --- FLOATING ROCKY TERRAIN PARTICLES --- */
  const rockCount = 120;
  const rockGeo = new THREE.BufferGeometry();
  const rockPos = new Float32Array(rockCount*3);
  const rockSizes = new Float32Array(rockCount);
  for(let i=0;i<rockCount;i++){
    rockPos[i*3]=(Math.random()-0.5)*30;
    rockPos[i*3+1]=(Math.random()-0.5)*12-3;
    rockPos[i*3+2]=(Math.random()-0.5)*20-5;
    rockSizes[i]=Math.random()*0.4+0.1;
  }
  rockGeo.setAttribute('position',new THREE.BufferAttribute(rockPos,3));
  const rockMat = new THREE.PointsMaterial({color:0x8899aa,size:0.18,sizeAttenuation:true,transparent:true,opacity:0.5});
  scene.add(new THREE.Points(rockGeo,rockMat));

  /* --- FIREFLIES --- */
  const ffCount = 80;
  const ffGeo = new THREE.BufferGeometry();
  const ffPos = new Float32Array(ffCount*3);
  const ffData = [];
  for(let i=0;i<ffCount;i++){
    ffPos[i*3]=(Math.random()-0.5)*20;
    ffPos[i*3+1]=(Math.random()-0.5)*8;
    ffPos[i*3+2]=(Math.random()-0.5)*14-3;
    ffData.push({ox:ffPos[i*3],oy:ffPos[i*3+1],oz:ffPos[i*3+2],phase:Math.random()*Math.PI*2,speed:0.3+Math.random()*0.5});
  }
  ffGeo.setAttribute('position',new THREE.BufferAttribute(ffPos,3));
  const ffMat = new THREE.PointsMaterial({color:0xe8ff47,size:0.12,sizeAttenuation:true,transparent:true,opacity:0.85});
  const fireflies = new THREE.Points(ffGeo,ffMat);
  scene.add(fireflies);

  /* --- MOUSE PARALLAX --- */
  let targetRotX=0,targetRotY=0,currentRotX=0,currentRotY=0;
  document.addEventListener('mousemove',e=>{
    targetRotY=(e.clientX/window.innerWidth-0.5)*0.3;
    targetRotX=-(e.clientY/window.innerHeight-0.5)*0.15;
  });

  /* --- RESIZE --- */
  window.addEventListener('resize',()=>{
    const w=canvas.parentElement.clientWidth, h=canvas.parentElement.clientHeight;
    renderer.setSize(w,h);
    camera.aspect=w/h;
    camera.updateProjectionMatrix();
  });

  /* --- ANIMATE --- */
  let t=0;
  function animate(){
    requestAnimationFrame(animate);
    t+=0.008;

    // Smooth camera parallax
    currentRotX+=(targetRotX-currentRotX)*0.04;
    currentRotY+=(targetRotY-currentRotY)*0.04;
    scene.rotation.x=currentRotX;
    scene.rotation.y=currentRotY;

    // Orb
    orb.rotation.y = t*0.08;
    ring.rotation.z = t*0.12;
    ring.rotation.x = Math.PI/2.4 + Math.sin(t*0.3)*0.05;

    // Accent light colour sync
    const ac=getAccentColor();
    accentLight.color.setRGB(ac.r/255,ac.g/255,ac.b/255);
    ringMat.color.setRGB(ac.r/255,ac.g/255,ac.b/255);
    ringMat.emissive.setRGB(ac.r/255*0.6,ac.g/255*0.9,ac.b/255*0.1);
    ffMat.color.setRGB(ac.r/255,ac.g/255,ac.b/255);

    // Fireflies
    const ffPositions=fireflies.geometry.attributes.position.array;
    for(let i=0;i<ffCount;i++){
      ffPositions[i*3]=ffData[i].ox+Math.sin(t*ffData[i].speed+ffData[i].phase)*1.2;
      ffPositions[i*3+1]=ffData[i].oy+Math.cos(t*ffData[i].speed*0.7+ffData[i].phase)*0.8;
      ffPositions[i*3+2]=ffData[i].oz+Math.sin(t*ffData[i].speed*0.5)*0.5;
    }
    fireflies.geometry.attributes.position.needsUpdate=true;
    ffMat.opacity=0.6+Math.sin(t*1.5)*0.25;

    // Birds
    birds.forEach(b=>{
      b.userData.theta+=b.userData.speed;
      const r=b.userData.radius;
      b.position.x=r*Math.cos(b.userData.theta);
      b.position.z=r*Math.sin(b.userData.theta)-6;
      b.position.y=b.userData.phi*6+Math.sin(t*0.8+b.userData.wobble)*0.6;
      b.rotation.y=-b.userData.theta-Math.PI/2;
      // Wing flap
      const flap=Math.sin(t*6+b.userData.wingPhase);
      b.userData.wingL.rotation.x=flap*0.6;
      b.userData.wingR.rotation.x=-flap*0.6;
      b.userData.wingL.position.y=Math.abs(flap)*0.05;
      b.userData.wingR.position.y=Math.abs(flap)*0.05;
    });

    renderer.render(scene,camera);
  }
  animate();
})();

/* ====================================================
   2D PARTICLES CANVAS (hero overlay)
   ==================================================== */
(function initParticles(){
  const c=document.getElementById('particles-canvas');
  const ctx=c.getContext('2d');
  function resize(){c.width=c.parentElement.clientWidth;c.height=c.parentElement.clientHeight;}
  resize();
  window.addEventListener('resize',resize);
  const pts=Array.from({length:60},()=>({
    x:Math.random()*c.width,y:Math.random()*c.height,
    vx:(Math.random()-0.5)*0.3,vy:(Math.random()-0.5)*0.3,
    r:Math.random()*1.5+0.3,life:Math.random()
  }));
  function draw(){
    ctx.clearRect(0,0,c.width,c.height);
    const ac=getAccentColor();
    pts.forEach(p=>{
      p.x+=p.vx; p.y+=p.vy; p.life+=0.004;
      if(p.x<0||p.x>c.width)p.vx*=-1;
      if(p.y<0||p.y>c.height)p.vy*=-1;
      const a=0.15+0.35*Math.sin(p.life*Math.PI);
      ctx.beginPath();
      ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(${ac.r},${ac.g},${ac.b},${a})`;
      ctx.fill();
    });
    // Draw connections
    ctx.strokeStyle=`rgba(${ac.r},${ac.g},${ac.b},0.04)`;
    ctx.lineWidth=0.5;
    for(let i=0;i<pts.length;i++) for(let j=i+1;j<pts.length;j++){
      const d=Math.hypot(pts[i].x-pts[j].x,pts[i].y-pts[j].y);
      if(d<90){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.stroke();}
    }
    requestAnimationFrame(draw);
  }
  draw();
})();

/* ====================================================
   MARQUEE
   ==================================================== */
(function buildMarquee(){
  const items=[...DB.marquee,...DB.marquee];
  document.getElementById('marquee-track').innerHTML=items.map(t=>`<span class="marquee-item">${t}</span>`).join('');
})();

/* ====================================================
   SKILLS
   ==================================================== */
function skillChip(s){
  return `<div class="skill-chip"><img src="${s.img}" alt="${s.name}" loading="lazy"/>${s.name}</div>`;
}
function renderSkills(ids){
  const half=Math.ceil(DB.skills.length/2);
  const r1=DB.skills.slice(0,half), r2=DB.skills.slice(half);
  const t1=document.getElementById(ids[0]), t2=document.getElementById(ids[1]);
  if(t1) t1.innerHTML=[...r1,...r1].map(skillChip).join('');
  if(t2) t2.innerHTML=[...r2,...r2].map(skillChip).join('');
}
renderSkills(['skills1','skills2']);

/* ====================================================
   PROJECTS
   ==================================================== */
let currentFilter='all', currentSearch='';

function projectCard(p){
  return `<div class="project-card" onclick="navigate('projects')" onmousemove="tiltCard(event,this)">
    <div class="project-card-inner">
      <img src="${p.img}" alt="${p.title}" loading="lazy"/>
      <div class="project-card-shine"></div>
    </div>
    <div class="project-card-body">
      <div class="project-card-tags">${p.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
      <div class="project-card-title">${p.title}</div>
      <div class="project-card-year">${p.year}</div>
    </div>
  </div>`;
}

function tiltCard(e,card){
  const r=card.getBoundingClientRect();
  const x=(e.clientX-r.left)/r.width-0.5;
  const y=(e.clientY-r.top)/r.height-0.5;
  card.style.transform=`perspective(800px) rotateY(${x*14}deg) rotateX(${-y*10}deg) translateZ(8px)`;
  const shine=card.querySelector('.project-card-shine');
  if(shine){shine.style.setProperty('--mx',(x+0.5)*100+'%');shine.style.setProperty('--my',(y+0.5)*100+'%');}
  card.addEventListener('mouseleave',()=>{card.style.transform='';},{ once:true});
}

function renderFeatured(){
  const featured=DB.projects.filter(p=>p.featured).slice(0,4);
  const el=document.getElementById('featured-projects');
  if(el) el.innerHTML=featured.map(projectCard).join('');
}
renderFeatured();

function renderAllProjects(filter,search=''){
  const grid=document.getElementById('all-projects');
  if(!grid) return;
  const filtered=DB.projects.filter(p=>{
    const mf=filter==='all'||p.tags.map(t=>t.toLowerCase()).includes(filter);
    const ms=!search||p.title.toLowerCase().includes(search.toLowerCase());
    return mf&&ms;
  });
  grid.innerHTML=filtered.map(projectCard).join('');
}

function filterProjects(f,btn){
  currentFilter=f;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderAllProjects(currentFilter,currentSearch);
}

function searchProjects(v){
  currentSearch=v;
  renderAllProjects(currentFilter,currentSearch);
}

/* ====================================================
   TESTIMONIALS
   ==================================================== */
function renderTestimonials(){
  const grid=document.getElementById('testimonials-grid');
  if(!grid) return;
  grid.innerHTML=DB.testimonials.map(t=>`
    <div class="testimonial-card">
      <div class="testimonial-author">
        <img src="${t.img}" alt="${t.name}" loading="lazy"/>
        <div><div class="testimonial-name">${t.name}</div><div class="testimonial-role">${t.role}</div></div>
      </div>
      <p class="testimonial-text">"${t.text}"</p>
    </div>`).join('');
}
renderTestimonials();

/* ====================================================
   GITHUB API
   ==================================================== */
async function fetchGitHub(){
  const LANG_COLORS={JavaScript:'#f1e05a',TypeScript:'#3178c6',Python:'#3572A5',CSS:'#563d7c',HTML:'#e34c26',Shell:'#89e051'};
  try {
    const res=await fetch(`https://api.github.com/users/abhisheksharma-github/repos?sort=updated&per_page=6`);
    if(!res.ok) throw new Error();
    const repos=await res.json();
    const grid=document.getElementById('repos-grid');
    if(!grid) return;
    const total=repos.length;
    document.getElementById('stat-gh').textContent=total+'+';
    grid.innerHTML=repos.slice(0,6).map(r=>`
      <a class="repo-card" href="${r.html_url}" target="_blank" rel="noopener">
        <div class="repo-name">⬡ ${r.name}</div>
        <div class="repo-desc">${r.description||'No description provided.'}</div>
        <div class="repo-meta">
          ${r.language?`<span class="repo-lang"><span class="lang-dot" style="background:${LANG_COLORS[r.language]||'var(--accent)'}"></span>${r.language}</span>`:''}
          <span>★ ${r.stargazers_count}</span>
          <span>⑂ ${r.forks_count}</span>
        </div>
      </a>`).join('');
  } catch(e) {
    // Fallback mock repos
    const grid=document.getElementById('repos-grid');
    if(grid) grid.innerHTML=`
      <a class="repo-card" href="#" target="_blank"><div class="repo-name">⬡ portfolio-v3</div><div class="repo-desc">My personal portfolio built with Next.js and Three.js</div><div class="repo-meta"><span class="repo-lang"><span class="lang-dot"></span>TypeScript</span><span>★ 42</span></div></a>
      <a class="repo-card" href="#" target="_blank"><div class="repo-name">⬡ code-screenshot</div><div class="repo-desc">Beautiful code screenshot generator with themes</div><div class="repo-meta"><span class="repo-lang"><span class="lang-dot" style="background:#3178c6"></span>TypeScript</span><span>★ 28</span></div></a>
      <a class="repo-card" href="#" target="_blank"><div class="repo-name">⬡ design-code-community</div><div class="repo-desc">Global community platform for designers & developers</div><div class="repo-meta"><span class="repo-lang"><span class="lang-dot" style="background:#f1e05a"></span>JavaScript</span><span>★ 15</span></div></a>
      <a class="repo-card" href="#" target="_blank"><div class="repo-name">⬡ snapalyzer</div><div class="repo-desc">AI-powered image analysis tool built with React</div><div class="repo-meta"><span class="repo-lang"><span class="lang-dot"></span>TypeScript</span><span>★ 19</span></div></a>
      <a class="repo-card" href="#" target="_blank"><div class="repo-name">⬡ aora</div><div class="repo-desc">Video sharing mobile app built with React Native</div><div class="repo-meta"><span class="repo-lang"><span class="lang-dot" style="background:#f1e05a"></span>JavaScript</span><span>★ 31</span></div></a>
      <a class="repo-card" href="#" target="_blank"><div class="repo-name">⬡ collabxweb</div><div class="repo-desc">Real-time collaboration platform for remote teams</div><div class="repo-meta"><span class="repo-lang"><span class="lang-dot" style="background:#3178c6"></span>TypeScript</span><span>★ 11</span></div></a>`;
    document.getElementById('stat-gh').textContent='10+';
  }
}
fetchGitHub();

/* ====================================================
   TABS
   ==================================================== */
function showTab(id,btn){
  document.querySelectorAll('.expertise-content').forEach(c=>c.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  btn.classList.add('active');
}

